.unlock-dialog-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(8, 8, 10, 0.42);
  backdrop-filter: blur(24rpx);
  box-sizing: border-box;
}

.unlock-dialog-mask-enter {
  animation: unlockDialogMaskEnter 0.24s ease both;
}

.unlock-dialog-mask-closing {
  animation: unlockDialogMaskExit 0.26s ease both;
}

.unlock-dialog {
  width: 100%;
  max-width: 664rpx;
  transform-origin: center center;
}

.unlock-dialog-enter {
  animation: unlockDialogEnter 0.26s cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.unlock-dialog-closing {
  animation: unlockDialogExit 0.24s ease both;
}

.unlock-dialog-panel {
  padding: 36rpx 32rpx 32rpx;
  border-radius: 16rpx;
  background:
    radial-gradient(circle at top, rgba(255, 255, 255, 0.08), transparent 40%),
    linear-gradient(180deg, rgba(29, 29, 31, 0.98), rgba(10, 10, 11, 1));
  box-shadow:
    0 48rpx 84rpx rgba(0, 0, 0, 0.2),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.12);
  box-sizing: border-box;
}

.unlock-dialog-title {
  display: block;
  color: rgba(255, 255, 255, 0.94);
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
}

.unlock-dialog-text {
  display: block;
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.58);
  font-size: 24rpx;
  line-height: 1.5;
}

.unlock-dialog-action {
  width: 100% !important;
  min-width: 0;
  height: 88rpx;
  margin: 24rpx 0 0 !important;
  padding: 0 28rpx;
  border: 0;
  border-radius: 1998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 28rpx;
  font-weight: 700;
}

.unlock-dialog-action::after {
  border: none;
}

.unlock-dialog-action-share {
  background: rgba(255, 255, 255, 0.96);
  color: #111111;
}

.unlock-dialog-action-share-disabled {
  background: rgba(255, 255, 255, 0.18);
  color: rgba(255, 255, 255, 0.38);
}

.unlock-dialog-action-video {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.94);
}

@keyframes unlockDialogMaskEnter {
  0% {
    opacity: 0;
  }

  100% {
    opacity: 1;
  }
}

@keyframes unlockDialogMaskExit {
  0% {
    opacity: 1;
  }

  100% {
    opacity: 0;
  }
}

@keyframes unlockDialogEnter {
  0% {
    opacity: 0;
    transform: scale(0.96);
  }

  100% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes unlockDialogExit {
  0% {
    opacity: 1;
    transform: scale(1);
  }

  100% {
    opacity: 0;
    transform: scale(0.96);
  }
}
