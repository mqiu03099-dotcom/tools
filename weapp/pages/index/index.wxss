@import "../../utils/unlock-dialog.wxss";

page {
  min-height: 100vh;
  background: #000000;
  width: 100%;
}

.page-shell {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #000000;
}

.home-main {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 0;
  width: 100%;
  box-sizing: border-box;
}

.home-panel {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.video-section {
  padding: 0;
  border: 0;
  border-radius: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
  background: #111111;
  box-sizing: border-box;
}

.hero-video-stage {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #000000;
}

.hero-video-clip {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #000000;
}

.hero-video-wrap {
  position: relative;
  width: auto;
  height: 100%;
  max-width: 100%;
  max-height: 100%;
  background: #000000;
}

.hero-video {
  display: block;
  width: 100%;
  height: 100%;
}

.hero-video-switching {
  opacity: 0;
}

.page-loading-mask,
.action-cover-loading {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.page-loading-mask {
  background: #000000;
}

.loading-image-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 1998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-image {
  width: 100%;
  height: 100%;
  display: block;
  filter: brightness(0) invert(1);
  animation: loadingRotate 0.9s linear infinite;
}

.video-state-icon-spinning {
  animation: statusIconSpin 5.6s linear infinite;
}

@keyframes statusIconSpin {
  0% {
    transform: rotate(0deg);
  }

  100% {
    transform: rotate(360deg);
  }
}

.content-section {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  box-sizing: border-box;
}

.mode-scroll {
  width: 100%;
}

.mode-track {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 20rpx;
  padding: 0;
  box-sizing: border-box;
}

.action-card {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  border: 0;
  border-radius: 16rpx;
  overflow: hidden;
  background: #050506;
  box-sizing: border-box;
}

.action-card-active {
  opacity: 0.82;
}

.action-cover-wrap {
  position: relative;
  width: 100%;
  height: 100%;
}

.action-cover {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
  background: #050506;
}

.action-cover-mask {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.action-cover-loading {
  background: rgba(255, 255, 255, 0.08);
  pointer-events: none;
}

@keyframes loadingRotate {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.action-current-badge {
  position: absolute;
  top: 12rpx;
  left: 50%;
  min-width: 60rpx;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 1998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(12, 12, 14, 0.78);
  backdrop-filter: blur(20rpx);
  box-sizing: border-box;
  z-index: 3;
  transform: translateX(-50%);
}

.action-current-text {
  color: #ffffff;
  font-size: 16rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 1.2rpx;
  text-align: center;
}

.action-card-copy {
  position: absolute;
  left: 0;
  right: 0;
  bottom: -2rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
  min-height: 40rpx;
  padding: 8rpx 12rpx 12rpx;
  background: rgba(0, 0, 0, 0.62);
  box-sizing: border-box;
  z-index: 3;
}

.action-card-title {
  color: rgba(255, 255, 255, 0.96);
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.15;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.home-tool-section {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.home-tool-row {
  width: 100%;
  min-height: 144rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(24rpx);
  box-sizing: border-box;
}

button.home-tool-row {
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  justify-content: center !important;
  width: 100% !important;
  min-height: 144rpx !important;
  margin: 0 !important;
  padding: 24rpx !important;
  line-height: 1 !important;
}

.home-tool-row::after {
  border: none;
}

.home-tool-row-active {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.18);
}

.home-tool-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: rgba(255, 176, 58, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.home-tool-icon {
  width: 30rpx;
  height: 30rpx;
  display: block;
  filter: brightness(0) saturate(100%) invert(73%) sepia(94%) saturate(1154%) hue-rotate(340deg)
    brightness(102%) contrast(102%);
}

.home-tool-cover {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: #050506;
  filter: none;
}

.home-tool-icon-loading {
  position: absolute;
  inset: 0;
  background: rgba(255, 255, 255, 0.08);
  pointer-events: none;
}

.home-tool-label {
  max-width: 100%;
  color: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
  font-weight: 400;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.safe-area-spacer {
  flex-shrink: 0;
  height: env(safe-area-inset-bottom);
  background: #000000;
}

.index-reward-shell {
  max-width: 664rpx;
}

.index-reward-dialog {
  width: 100%;
}
