<view class="home-detail-page">
  <scroll-view
    class="home-detail-scroll"
    scroll-y="{{ true }}"
    enhanced="{{ true }}"
    show-scrollbar="{{ false }}"
  >
    <view class="home-detail-scroll-body">
      <page-header
        title="奶呱视频详情"
        description="精选奶呱魔性视频封面，可预览后分享保存或看视频保存。"
        tags="{{ headerTags }}"
      ></page-header>

      <ad-custom unit-id="adunit-07d67250772c2f4d"></ad-custom>

      <view class="home-detail-content">
        <image
          wx:if="{{ imageUrl }}"
          class="home-detail-image"
          src="{{ imageUrl }}"
          mode="widthFix"
          show-menu-by-longpress="{{ true }}"
        ></image>
      </view>
    </view>
  </scroll-view>

  <detail-save-actions
    image-url="{{ imageUrl }}"
    denied-modal-content="{{ photoAlbumDeniedContent }}"
  ></detail-save-actions>
  <view class="safe-area-spacer"></view>
</view>
