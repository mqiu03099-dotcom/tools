.feedback-page {
  min-height: 100vh;
  width: 100%;
  display: flex;
  flex-direction: column;
  background: #000000;
  box-sizing: border-box;
}

.feedback-page-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0;
  box-sizing: border-box;
}

.feedback-panel {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 28rpx 24rpx;
  background: #111111;
  box-sizing: border-box;
}

.feedback-title {
  color: rgba(255, 255, 255, 0.94);
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.25;
}

.feedback-description {
  color: rgba(255, 255, 255, 0.58);
  font-size: 26rpx;
  line-height: 1.6;
}

.feedback-textarea-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.feedback-textarea-placeholder {
  position: absolute;
  top: 28rpx;
  left: 28rpx;
  right: 28rpx;
  z-index: 1;
  color: rgba(255, 255, 255, 0.38);
  font-size: 26rpx;
  line-height: 1.6;
  pointer-events: none;
}

.feedback-textarea {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 320rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.feedback-submit {
  width: 100%;
  height: 88rpx;
  border-radius: 1998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.94);
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
  box-sizing: border-box;
}
