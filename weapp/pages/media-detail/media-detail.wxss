.media-detail-page {
  height: 100vh;
  width: 100%;
  display: flex;
  flex-direction: column;
  padding: 0;
  background: #000000;
  overflow: hidden;
  box-sizing: border-box;
}

.media-detail-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
  background: #000000;
}

.media-detail-scroll-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0;
  box-sizing: border-box;
}

.media-detail-intro {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 0;
  background: #111111;
  box-sizing: border-box;
}

.media-detail-intro-title {
  display: block;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.media-detail-intro-text {
  display: block;
  color: rgba(255, 255, 255, 0.62);
  font-size: 26rpx;
  line-height: 1.7;
}

.media-detail-intro-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.media-detail-intro-tag {
  padding: 12rpx 20rpx;
  border-radius: 1998rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  line-height: 1;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  box-sizing: border-box;
}

.media-detail-intro-tag-primary {
  color: #d3f3ea;
  background: rgba(114, 176, 160, 0.18);
  border-color: rgba(114, 176, 160, 0.28);
  font-weight: 700;
}

.media-detail-content {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  background: #000000;
  box-sizing: border-box;
}

.media-detail-image {
  width: 100%;
  height: auto;
  display: block;
}

.media-detail-footer {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 24rpx;
  background: #000000;
  box-sizing: border-box;
}

.media-detail-action {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  border: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  border-radius: 1998rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.media-detail-action::after {
  border: none;
}

.media-detail-action-share {
  color: #111111;
  background: rgba(255, 255, 255, 0.96);
}

.media-detail-action-video {
  color: rgba(255, 255, 255, 0.94);
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.media-detail-action-disabled {
  opacity: 0.48;
}
