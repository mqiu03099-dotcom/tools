<view class="audio-page">
  <view class="audio-page-body">
    <page-header
      title="{{ pageHeader.title }}"
      description="{{ pageHeader.description }}"
      tags="{{ pageHeader.tags }}"
    ></page-header>

    <view
      wx:if="{{ isAudioLoading }}"
      class="audio-loading"
    >
      <view class="audio-loading-image-wrap">
        <image
          class="audio-loading-image"
          src="{{ loadingImageUrl }}"
          mode="aspectFit"
        ></image>
      </view>
      <view class="audio-loading-text">{{ audioText.loadingText }}</view>
    </view>

    <media-waterfall
      wx:else
      items="{{ audioItems }}"
      bind:itemtap="handleWaterfallItemTap"
    ></media-waterfall>
  </view>

  <view class="safe-area-spacer"></view>
</view>
