@import "../../utils/unlock-dialog.wxss";

.audio-detail-page {
  min-height: 100vh;
  width: 100%;
  background: #000000;
  color: #ffffff;
}

.audio-detail-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0;
  width: 100%;
  box-sizing: border-box;
}

.audio-detail-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 36rpx 0 12rpx;
}

.audio-detail-loading-image-wrap {
  width: 36rpx;
  height: 36rpx;
  border-radius: 1998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.audio-detail-loading-image {
  width: 100%;
  height: 100%;
  display: block;
  filter: brightness(0) invert(1);
  animation: audioDetailRotate 0.9s linear infinite;
}

.audio-detail-loading-text {
  color: rgba(255, 255, 255, 0.48);
  font-size: 20rpx;
  line-height: 1;
}

.phonograph-panel {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding: 24rpx 20rpx 36rpx;
  box-sizing: border-box;
}

.phonograph-stage {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 520rpx;
  padding: 48rpx 20rpx 36rpx;
  border-radius: 20rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02)),
    #101010;
  box-sizing: border-box;
  overflow: hidden;
}

.record-base {
  width: 420rpx;
  height: 420rpx;
  padding: 28rpx;
  border-radius: 1998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    repeating-radial-gradient(circle, #191919 0, #191919 10rpx, #111111 12rpx, #111111 20rpx),
    #151515;
  box-sizing: border-box;
}

.record-disc {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 1998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    repeating-radial-gradient(circle, rgba(255, 255, 255, 0.1) 0, rgba(255, 255, 255, 0.1) 2rpx, transparent 4rpx, transparent 22rpx),
    radial-gradient(circle, #202020 0%, #050505 68%, #000000 100%);
  overflow: hidden;
}

.record-disc-playing {
  animation: audioDetailRotate 3.8s linear infinite;
}

.record-cover {
  width: 178rpx;
  height: 178rpx;
  border-radius: 1998rpx;
  background: #1a1a1a;
}

.record-core {
  position: absolute;
  width: 34rpx;
  height: 34rpx;
  border-radius: 1998rpx;
  background: #f5f5f5;
}

.phonograph-arm {
  position: absolute;
  top: 52rpx;
  right: 74rpx;
  width: 168rpx;
  height: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0;
  transform: rotate(22deg);
  transform-origin: 138rpx 28rpx;
  z-index: 2;
}

.phonograph-arm-line {
  width: 28rpx;
  height: 164rpx;
  border-radius: 1998rpx;
  background: linear-gradient(180deg, #f2f2f2, #8f8f8f);
}

.phonograph-needle {
  width: 68rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: #d7d7d7;
  transform: rotate(42deg);
}

.audio-detail-share-shell {
  max-width: 664rpx;
}

@keyframes audioDetailRotate {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
