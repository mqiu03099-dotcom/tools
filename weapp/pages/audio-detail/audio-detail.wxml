<view class="audio-detail-page">
  <view class="audio-detail-body">
    <page-header
      title="{{ pageHeader.title }}"
      description="{{ pageHeader.description }}"
      tags="{{ pageHeader.tags }}"
    ></page-header>

    <ad-custom unit-id="adunit-07d67250772c2f4d"></ad-custom>

    <view
      wx:if="{{ isDetailLoading }}"
      class="audio-detail-loading"
    >
      <view class="audio-detail-loading-image-wrap">
        <image
          class="audio-detail-loading-image"
          src="{{ loadingImageUrl }}"
          mode="aspectFit"
        ></image>
      </view>
      <view class="audio-detail-loading-text">{{ detailText.loadingText }}</view>
    </view>

    <view
      wx:else
      class="phonograph-panel"
    >
      <view class="phonograph-stage">
        <view class="phonograph-arm">
          <view class="phonograph-arm-line"></view>
          <view class="phonograph-needle"></view>
        </view>

        <view class="record-base">
          <view class="record-disc {{ isAudioPlaying ? 'record-disc-playing' : '' }}">
            <image
              class="record-cover"
              src="{{ cover }}"
              mode="aspectFill"
            ></image>
            <view class="record-core"></view>
          </view>
        </view>
      </view>

      <audio-detail-actions
        is-playing="{{ isAudioPlaying }}"
        is-starting="{{ isAudioStarting }}"
        play-image-url="{{ playImageUrl }}"
        stop-play-image-url="{{ stopPlayImageUrl }}"
        loading-image-url="{{ loadingImageUrl }}"
        download-image-url="{{ downloadImageUrl }}"
        play-text="{{ detailText.playText }}"
        pause-text="{{ detailText.pauseText }}"
        download-text="{{ detailText.downloadText }}"
        bind:toggleplay="handleTogglePlay"
        bind:download="handleDownloadTap"
      ></audio-detail-actions>
    </view>
  </view>

  <view class="safe-area-spacer"></view>

  <view
    wx:if="{{ isAudioShareDialogVisible }}"
    class="unlock-dialog-mask audio-detail-share-mask unlock-dialog-mask-enter"
    catchtouchmove="noop"
    bindtap="closeAudioShareDialog"
  >
    <view
      class="unlock-dialog audio-detail-share-shell unlock-dialog-enter"
      catchtap="noop"
      catchtouchmove="noop"
    >
      <view class="unlock-dialog-panel audio-detail-share-dialog">
        <view class="unlock-dialog-title">{{ detailText.readyDialogTitle }}</view>
        <view class="unlock-dialog-text">{{ detailText.readyDialogText }}</view>
        <view
          class="unlock-dialog-action unlock-dialog-action-share"
          bindtap="handleSharePreparedAudioTap"
        >
          {{ detailText.readyDialogAction }}
        </view>
      </view>
    </view>
  </view>
</view>
