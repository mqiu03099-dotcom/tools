.shape-cut-page {
  min-height: 100vh;
  width: 100%;
  background: #000000;
}

.shape-cut-page-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0;
  width: 100%;
  box-sizing: border-box;
}

.shape-cut-page-intro,
.shape-cut-empty,
.shape-cut-editor-card,
.shape-cut-result-card {
  padding: 20rpx;
  border-radius: 0;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.92), transparent 36%),
    linear-gradient(180deg, #f8f9fb 0%, #f1f4f7 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
}

.shape-cut-page-intro-title {
  display: block;
  color: #111111;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.shape-cut-page-intro-text,
.shape-cut-empty-text {
  display: block;
  margin-top: 16rpx;
  color: rgba(17, 17, 17, 0.62);
  font-size: 26rpx;
  line-height: 1.7;
}

.shape-cut-page-intro-tags-scroll {
  width: 100%;
  margin-top: 20rpx;
}

.shape-cut-page-intro-tags,
.shape-cut-chip-row {
  display: inline-flex;
  flex-wrap: nowrap;
  gap: 20rpx;
  white-space: nowrap;
}

.shape-cut-page-intro-tag {
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  border-radius: 1998rpx;
  color: rgba(17, 17, 17, 0.72);
  font-size: 22rpx;
  line-height: 1;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid rgba(17, 17, 17, 0.05);
  box-sizing: border-box;
}

.shape-cut-page-intro-tag-primary {
  color: #2f4f76;
  font-weight: 700;
  letter-spacing: 2rpx;
  background: linear-gradient(180deg, rgba(228, 238, 248, 0.98), rgba(211, 226, 242, 0.98));
  border-color: rgba(74, 112, 158, 0.28);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
}

.shape-cut-empty-title,
.shape-cut-section-title,
.shape-cut-config-title {
  display: block;
  color: #111111;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.3;
}

.shape-cut-editor-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.shape-cut-editor-tip {
  flex-shrink: 0;
  color: rgba(47, 79, 118, 0.88);
  font-size: 22rpx;
  line-height: 1;
  padding: 8rpx 16rpx;
  border-radius: 1998rpx;
  background: rgba(228, 238, 248, 0.9);
  border: 2rpx solid rgba(74, 112, 158, 0.16);
  white-space: nowrap;
}

.shape-cut-editor-frame {
  position: relative;
  overflow: hidden;
  margin: 20rpx auto 0;
  max-width: 100%;
  border-radius: 16rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.24), rgba(255, 255, 255, 0)), #eef1f5;
  box-shadow:
    inset 0 0 0 2rpx rgba(17, 17, 17, 0.05),
    0 20rpx 48rpx rgba(17, 17, 17, 0.06);
}

.shape-cut-editor-image {
  position: absolute;
  display: block;
}

.shape-cut-editor-outline-wrap {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.shape-cut-editor-outline {
  position: absolute;
  box-sizing: border-box;
  pointer-events: auto;
  border-radius: 16rpx;
  box-shadow: 0 0 0 19998rpx rgba(17, 17, 17, 0.18);
}

.shape-cut-editor-highlight {
  position: absolute;
  inset: 0;
  border-radius: 16rpx;
  background: rgba(79, 140, 255, 0.14);
  box-shadow:
    inset 0 0 0 4rpx rgba(109, 167, 255, 0.9),
    inset 0 0 48rpx rgba(109, 167, 255, 0.12);
  pointer-events: none;
}

.shape-cut-config-card {
  margin-top: 28rpx;
}

.shape-cut-chip-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  margin-top: 20rpx;
  gap: 20rpx;
}

.shape-cut-chip {
  flex: 0 0 auto;
  padding: 16rpx 20rpx;
  border-radius: 1998rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 2rpx solid rgba(17, 17, 17, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.shape-cut-chip-active {
  background: linear-gradient(180deg, rgba(228, 238, 248, 0.98), rgba(211, 226, 242, 0.98));
  border-color: rgba(74, 112, 158, 0.28);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
}

.shape-cut-chip-text {
  color: rgba(17, 17, 17, 0.74);
  font-size: 20rpx;
  line-height: 1;
}

.shape-cut-chip-active .shape-cut-chip-text {
  color: #2f4f76;
  font-weight: 700;
}

.shape-cut-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 28rpx;
}

.shape-cut-primary-btn,
.shape-cut-secondary-btn {
  width: 100% !important;
  min-width: 0;
  height: 88rpx;
  margin: 0 !important;
  padding: 0 28rpx;
  border: 0;
  border-radius: 1998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 28rpx;
  font-weight: 700;
}

.shape-cut-primary-btn::after,
.shape-cut-secondary-btn::after {
  border: none;
}

.shape-cut-primary-btn {
  background: #111111;
  color: #ffffff;
}

.shape-cut-empty .shape-cut-primary-btn,
.shape-cut-result-card .shape-cut-primary-btn {
  margin-top: 28rpx !important;
}

.shape-cut-secondary-btn {
  background: #eceff3;
  color: rgba(17, 17, 17, 0.78);
}

.shape-cut-save-hint {
  display: block;
  margin-top: 20rpx;
  color: rgba(17, 17, 17, 0.56);
  font-size: 20rpx;
  line-height: 1.4;
  text-align: center;
}

.shape-cut-result-preview {
  position: relative;
  width: 100%;
  margin-top: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background:
    linear-gradient(
      45deg,
      rgba(17, 17, 17, 0.04) 25%,
      transparent 25%,
      transparent 75%,
      rgba(17, 17, 17, 0.04) 75%
    ),
    linear-gradient(
      45deg,
      rgba(17, 17, 17, 0.04) 25%,
      transparent 25%,
      transparent 75%,
      rgba(17, 17, 17, 0.04) 75%
    ),
    #eef1f5;
  background-position:
    0 0,
    20rpx 20rpx;
  background-size: 40rpx 40rpx;
}

.shape-cut-result-spacer {
  padding-top: 100%;
}

.shape-cut-result-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.shape-cut-hidden-canvas {
  position: fixed;
  left: -19998rpx;
  top: -19998rpx;
  opacity: 0;
  pointer-events: none;
}

.shape-cut-page {
  background: #000000;
  color: #ffffff;
}

.shape-cut-page-intro-title,
.shape-cut-empty-title,
.shape-cut-section-title,
.shape-cut-config-title {
  color: #ffffff;
}

.shape-cut-page-intro,
.shape-cut-empty,
.shape-cut-editor-card,
.shape-cut-result-card {
  border-radius: 0;
  background: #111111;
  box-shadow: none;
}

.shape-cut-page-intro-text,
.shape-cut-empty-text,
.shape-cut-save-hint {
  color: rgba(255, 255, 255, 0.62);
}

.shape-cut-page-intro-tag,
.shape-cut-editor-tip,
.shape-cut-chip {
  color: rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.1);
}

.shape-cut-page-intro-tag-primary,
.shape-cut-chip-active {
  color: #d3f3ea;
  background: rgba(114, 176, 160, 0.18);
  border-color: rgba(114, 176, 160, 0.28);
  box-shadow: none;
}

.shape-cut-chip-text {
  color: rgba(255, 255, 255, 0.72);
}

.shape-cut-chip-active .shape-cut-chip-text {
  color: #d3f3ea;
}

.shape-cut-editor-frame,
.shape-cut-result-preview {
  border-radius: 16rpx;
  background: #1a1a1a;
  box-shadow: none;
}

.shape-cut-editor-outline,
.shape-cut-editor-highlight {
  border-radius: 16rpx;
}

.shape-cut-primary-btn,
.shape-cut-secondary-btn {
  border-radius: 1998rpx;
}

.shape-cut-primary-btn {
  background: #ffffff;
  color: #111111;
}

.shape-cut-secondary-btn {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.82);
}
