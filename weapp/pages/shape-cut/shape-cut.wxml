<view class="shape-cut-page">
  <view class="shape-cut-page-body">
    <view class="shape-cut-page-intro">
      <text class="shape-cut-page-intro-title">图片裁剪</text>
      <text class="shape-cut-page-intro-text"
        >上传一张图片后，自由拖动位置和缩放大小，裁成爱心、圆形、小圆角或长方形样式。</text
      >
      <scroll-view
        class="shape-cut-page-intro-tags-scroll"
        scroll-x="{{ true }}"
        enable-flex="{{ true }}"
        show-scrollbar="{{ false }}"
      >
        <view class="shape-cut-page-intro-tags">
          <block
            wx:for="{{ pageIntroTags }}"
            wx:key="*this"
            wx:for-index="index"
          >
            <text
              class="shape-cut-page-intro-tag {{
                index === 0 ? 'shape-cut-page-intro-tag-primary' : ''
              }}"
              >{{ item }}</text
            >
          </block>
        </view>
      </scroll-view>
    </view>

    <ad-custom unit-id="{{ nativeTemplateAdUnitId }}"></ad-custom>

    <view
      wx:if="{{ !sourceImagePath }}"
      class="shape-cut-empty"
    >
      <text class="shape-cut-empty-title">选择图片开始裁剪</text>
      <text class="shape-cut-empty-text"
        >生成后的图片默认是透明底 PNG，适合做头像、贴纸和素材图。</text
      >
      <button
        class="shape-cut-primary-btn"
        bindtap="chooseSourceImage"
      >
        选择图片
      </button>
    </view>

    <block wx:else>
      <view class="shape-cut-editor-card">
        <view class="shape-cut-editor-head">
          <text class="shape-cut-section-title">调整图片位置</text>
          <text class="shape-cut-editor-tip">拖动白线框调整区域</text>
        </view>
        <view
          id="shapeCutEditorFrame"
          class="shape-cut-editor-frame"
          style="width: {{ cropBoxSizeRpx }}rpx; height: {{ editorViewportHeightRpx }}rpx;"
        >
          <image
            class="shape-cut-editor-image"
            src="{{ sourceImagePath }}"
            mode="scaleToFill"
            style="{{ editorImageStyle }}"
          ></image>
          <view
            class="shape-cut-editor-outline-wrap shape-cut-editor-outline-wrap-{{ currentShapeId }}"
          >
            <view
              class="shape-cut-editor-outline shape-cut-editor-outline-{{ currentShapeId }}"
              style="{{ frameStyle }}"
              catchtouchstart="handleFrameTouchStart"
              catchtouchmove="handleFrameTouchMove"
              catchtouchend="handleFrameTouchEnd"
              catchtouchcancel="handleFrameTouchEnd"
            >
              <view class="shape-cut-editor-highlight"></view>
            </view>
          </view>
        </view>

        <view class="shape-cut-config-card">
          <text class="shape-cut-config-title">选择裁剪形状</text>
          <view class="shape-cut-chip-row">
            <block
              wx:for="{{ shapeOptions }}"
              wx:key="id"
            >
              <view
                class="shape-cut-chip {{
                  currentShapeId === item.id ? 'shape-cut-chip-active' : ''
                }}"
                bindtap="selectShape"
                data-shape-id="{{ item.id }}"
              >
                <view class="shape-cut-chip-text">{{ item.title }}</view>
              </view>
            </block>
          </view>
        </view>

        <view class="shape-cut-actions">
          <button
            class="shape-cut-secondary-btn"
            bindtap="chooseSourceImage"
          >
            重选图片
          </button>
          <button
            class="shape-cut-primary-btn"
            loading="{{ isGenerating }}"
            bindtap="generateShapeImage"
          >
            {{ isGenerating ? "生成中" : "生成图片" }}
          </button>
        </view>
      </view>

      <view
        wx:if="{{ generatedImagePath }}"
        class="shape-cut-result-card"
      >
        <text class="shape-cut-section-title">裁剪结果</text>
        <view class="shape-cut-result-preview">
          <view
            class="shape-cut-result-spacer"
            style="padding-top: {{ resultPreviewPaddingTop }};"
          ></view>
          <image
            class="shape-cut-result-image"
            src="{{ generatedImagePath }}"
            mode="aspectFit"
          ></image>
        </view>
        <button
          class="shape-cut-primary-btn"
          loading="{{ isSaving }}"
          bindtap="handleSaveActionTap"
        >
          {{ isSaving ? "保存中" : saveActionButtonText }}
        </button>
        <text class="shape-cut-save-hint">{{ saveActionHintText }}</text>
      </view>
    </block>
  </view>

  <view class="safe-area-spacer"></view>

  <canvas
    class="shape-cut-hidden-canvas"
    canvas-id="shapeCutCanvas"
    style="{{ canvasStyle }}"
  ></canvas>
</view>

