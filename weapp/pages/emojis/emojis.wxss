@import "../../utils/unlock-dialog.wxss";

.emojis-page {
  min-height: 100vh;
  width: 100%;
  background: #000000;
}

.emojis-page-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0;
  width: 100%;
  box-sizing: border-box;
}

.emojis-page-intro {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 0;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.92), transparent 36%),
    linear-gradient(180deg, #f8f9fb 0%, #f1f4f7 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
}

.emojis-page-intro-title {
  display: block;
  color: #111111;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
  letter-spacing: 0.8rpx;
}

.emojis-page-intro-text {
  display: block;
  color: rgba(17, 17, 17, 0.62);
  font-size: 26rpx;
  line-height: 1.7;
}

.emojis-page-intro-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.emojis-page-intro-tag {
  padding: 12rpx 20rpx;
  border-radius: 1998rpx;
  color: rgba(17, 17, 17, 0.72);
  font-size: 22rpx;
  line-height: 1;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid rgba(17, 17, 17, 0.05);
  box-sizing: border-box;
}

.emojis-page-intro-tag-primary {
  color: #2f4f76;
  font-weight: 700;
  letter-spacing: 2rpx;
  background: linear-gradient(180deg, rgba(228, 238, 248, 0.98), rgba(211, 226, 242, 0.98));
  border-color: rgba(74, 112, 158, 0.28);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
}

.emojis-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 36rpx 0 12rpx;
}

.emojis-loading-image-wrap {
  width: 36rpx;
  height: 36rpx;
  border-radius: 1998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.emojis-loading-image {
  width: 100%;
  height: 100%;
  display: block;
  filter: brightness(0) invert(1);
  animation: emojisLoadingRotate 0.9s linear infinite;
}

@keyframes emojisLoadingRotate {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.emojis-loading-text {
  color: rgba(17, 17, 17, 0.46);
  font-size: 20rpx;
  line-height: 1;
}

.emojis-group-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 0;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.92), transparent 36%),
    linear-gradient(180deg, #f8f9fb 0%, #f1f4f7 100%);
  box-sizing: border-box;
}

.emojis-group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.emojis-group-title {
  flex: 1;
  color: #111111;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.3;
}

.emojis-group-action {
  min-width: 0;
  margin: 0 !important;
  padding: 12rpx 20rpx;
  height: auto;
  line-height: 1;
  border: 0;
  border-radius: 1998rpx;
  display: inline-flex;
  align-items: center;
  color: #2f4f76;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  width: max-content;
  max-width: 100%;
  background: linear-gradient(180deg, rgba(228, 238, 248, 0.98), rgba(211, 226, 242, 0.98));
  border: 2rpx solid rgba(74, 112, 158, 0.28);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
}

.emojis-group-action-text {
  line-height: 1;
}

.emojis-group-scroll {
  width: 100%;
}

.emojis-group-thumb-list {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 20rpx;
}

.emojis-image-box {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 16rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #edf1f5 0%, #e3e8ee 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.78);
}

.emojis-image-box-image {
  width: 100%;
  height: 100%;
  display: block;
}

.emojis-preview-dialog {
  padding-top: 36rpx;
}

.emojis-preview-shell {
  max-width: 664rpx;
}

.emojis-preview-image-wrap {
  margin: 28rpx 0 20rpx;
  aspect-ratio: 1 / 1;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #f3f5f8 0%, #e8edf2 100%);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.emojis-preview-image {
  width: 100%;
  height: 100%;
  display: block;
}

.emojis-preview-group-scroll {
  width: 100%;
  max-height: 472rpx;
  margin: 28rpx 0 20rpx;
}

.emojis-preview-group-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 16rpx;
}

.emojis-preview-group-item {
  aspect-ratio: 1 / 1;
  border-radius: 16rpx;
  overflow: hidden;
  background: #1a1a1a;
}

.emojis-preview-group-image {
  width: 100%;
  height: 100%;
  display: block;
}

.emojis-page {
  background: #000000;
  color: #ffffff;
}

.emojis-page-intro-title,
.emojis-group-title {
  color: #ffffff;
}

.emojis-page-intro,
.emojis-group-card {
  border-radius: 0;
  background: #111111;
  box-shadow: none;
}

.emojis-page-intro-text {
  color: rgba(255, 255, 255, 0.62);
}

.emojis-page-intro-tag {
  color: rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.1);
}

.emojis-page-intro-tag-primary,
.emojis-group-action {
  color: #d3f3ea;
  background: rgba(114, 176, 160, 0.18);
  border-color: rgba(114, 176, 160, 0.28);
  box-shadow: none;
}

.emojis-loading-text {
  color: rgba(255, 255, 255, 0.48);
}

.emojis-image-box,
.emojis-preview-image-wrap {
  border-radius: 16rpx;
  background: #1a1a1a;
  box-shadow: none;
}
