.image-media-detail-page {
  min-height: 100vh;
  width: 100%;
  display: flex;
  flex-direction: column;
  background: #000000;
}

.image-media-detail-scroll {
  flex: 1;
  min-height: 0;
}

.image-media-detail-scroll-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 0 24rpx;
  box-sizing: border-box;
}

.image-media-detail-content {
  display: flex;
  justify-content: center;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.image-media-detail-image {
  width: 100%;
  border-radius: 16rpx;
  background: #111111;
}
