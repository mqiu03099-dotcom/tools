.image-media-list-page {
  min-height: 100vh;
  width: 100%;
  background: #000000;
  color: #ffffff;
}

.image-media-list-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 0 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.image-media-list-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 36rpx 24rpx 12rpx;
}

.image-media-list-loading-image-wrap {
  width: 36rpx;
  height: 36rpx;
  border-radius: 1998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-media-list-loading-image {
  width: 100%;
  height: 100%;
  display: block;
  filter: brightness(0) invert(1);
  animation: imageMediaListLoadingRotate 0.9s linear infinite;
}

.image-media-list-loading-text {
  color: rgba(255, 255, 255, 0.48);
  font-size: 20rpx;
  line-height: 1;
}

@keyframes imageMediaListLoadingRotate {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
