.page-header {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 24rpx;
  background: #111111;
  box-sizing: border-box;
}

.page-header-title {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.page-header-description {
  color: rgba(255, 255, 255, 0.62);
  font-size: 26rpx;
  line-height: 1.7;
}

.page-header-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.page-header-tag {
  padding: 12rpx 20rpx;
  border-radius: 1998rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  line-height: 1;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  box-sizing: border-box;
}

.page-header-tag-primary {
  color: #d3f3ea;
  font-weight: 700;
  background: rgba(114, 176, 160, 0.18);
  border-color: rgba(114, 176, 160, 0.28);
}
