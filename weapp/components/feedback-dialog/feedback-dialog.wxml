<view
  wx:if="{{ visible }}"
  class="feedback-mask {{ closing ? 'feedback-mask-closing' : 'feedback-mask-enter' }}"
  bindtap="handleMaskTap"
  catchtouchmove="noop"
>
  <view
    class="feedback-popup {{ closing ? 'feedback-popup-closing' : 'feedback-popup-enter' }}"
    catchtap="noop"
    catchtouchmove="noop"
  >
    <view class="feedback-header">
      <text class="feedback-title">反馈</text>
      <view class="feedback-description">
        可以把你遇到的问题、想要新增的功能，或者想吐槽的地方告诉我们，我们会认真看。
      </view>
    </view>

    <view class="feedback-body">
      <view class="feedback-textarea-wrap">
        <view
          wx:if="{{ !value }}"
          class="feedback-textarea-placeholder"
        >
          比如：希望增加更多壁纸、语音分类，或者告诉我们哪里不好用。
        </view>

        <textarea
          class="feedback-textarea"
          value="{{ value }}"
          maxlength="200"
          adjust-position="{{ false }}"
          cursor-spacing="24"
          show-confirm-bar="{{ false }}"
          hold-keyboard="{{ true }}"
          bindinput="handleInput"
        ></textarea>
      </view>

      <button
        class="feedback-submit"
        bindtap="handleSubmit"
      >
        提交反馈
      </button>
    </view>
  </view>
</view>
