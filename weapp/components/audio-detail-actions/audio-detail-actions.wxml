<view class="audio-detail-actions">
  <view
    class="audio-detail-action audio-detail-play-action"
    bindtap="handleTogglePlay"
  >
    <image
      wx:if="{{ isStarting }}"
      class="audio-detail-action-icon audio-detail-action-loading"
      src="{{ loadingImageUrl }}"
      mode="aspectFit"
    ></image>
    <image
      wx:else
      class="audio-detail-action-icon"
      src="{{ isPlaying ? stopPlayImageUrl : playImageUrl }}"
      mode="aspectFit"
    ></image>
    <view class="audio-detail-action-label">{{ isPlaying ? pauseText : playText }}</view>
  </view>

  <view
    class="audio-detail-action audio-detail-download-action"
    bindtap="handleDownloadTap"
  >
    <image
      class="audio-detail-action-icon audio-detail-download-icon"
      src="{{ downloadImageUrl }}"
      mode="aspectFit"
    ></image>
    <view class="audio-detail-action-label">{{ downloadText }}</view>
  </view>
</view>
