.media-waterfall {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.media-waterfall-grid {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.media-waterfall-ad {
  width: 100%;
}

.media-waterfall-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.media-waterfall-card {
  width: 100%;
  border-radius: 16rpx;
  overflow: hidden;
  background: #1a1a1a;
}

.media-waterfall-image {
  width: 100%;
  display: block;
}
