.detail-save-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: #000000;
  box-sizing: border-box;
}

.detail-save-action {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  border: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  border-radius: 1998rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.detail-save-action-share {
  color: #111111;
  background: rgba(255, 255, 255, 0.96);
}

.detail-save-action-video {
  color: rgba(255, 255, 255, 0.94);
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.detail-save-action-disabled {
  opacity: 0.48;
}
