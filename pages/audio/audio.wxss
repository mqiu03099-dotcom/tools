@import "../../utils/unlock-dialog.wxss";

.audio-page {
  min-height: 100vh;
  width: 100%;
  background: #000000;
}

.audio-page-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0;
  width: 100%;
  box-sizing: border-box;
}

.audio-page-intro {
  padding: 20rpx;
  border-radius: 0;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.92), transparent 36%),
    linear-gradient(180deg, #f8f9fb 0%, #f1f4f7 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
}

.audio-page-intro-title {
  display: block;
  color: #111111;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
  letter-spacing: 0.8rpx;
}

.audio-page-intro-text {
  display: block;
  margin-top: 16rpx;
  color: rgba(17, 17, 17, 0.62);
  font-size: 26rpx;
  line-height: 1.7;
}

.audio-page-intro-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}

.audio-page-intro-tag {
  padding: 12rpx 20rpx;
  border-radius: 1998rpx;
  color: rgba(17, 17, 17, 0.72);
  font-size: 22rpx;
  line-height: 1;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid rgba(17, 17, 17, 0.05);
  box-sizing: border-box;
}

.audio-page-intro-tag-primary {
  color: #2f4f76;
  font-weight: 700;
  letter-spacing: 2rpx;
  background: linear-gradient(180deg, rgba(228, 238, 248, 0.98), rgba(211, 226, 242, 0.98));
  border-color: rgba(74, 112, 158, 0.28);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
}

.audio-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 20rpx;
}

.audio-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 36rpx 0 12rpx;
}

.audio-loading-image-wrap {
  width: 36rpx;
  height: 36rpx;
  border-radius: 1998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.audio-loading-image {
  width: 100%;
  height: 100%;
  display: block;
  filter: brightness(0) invert(1);
  animation: audioLoadingRotate 0.9s linear infinite;
}

.audio-loading-text {
  color: rgba(17, 17, 17, 0.46);
  font-size: 20rpx;
  line-height: 1;
}

.audio-grid-card {
  display: grid;
  grid-template-columns: 104rpx minmax(0, 1fr) 64rpx 64rpx 64rpx;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 0;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.92), transparent 36%),
    linear-gradient(180deg, #f8f9fb 0%, #f1f4f7 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
}

.audio-card-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #edf1f5 0%, #e3e8ee 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.78);
}

.audio-card-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.audio-card-title {
  color: #111111;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
}

.audio-card-text {
  margin-top: 12rpx;
  color: rgba(17, 17, 17, 0.56);
  font-size: 20rpx;
  line-height: 1.5;
}

.audio-card-btn {
  width: 64rpx !important;
  min-width: 64rpx !important;
  height: 64rpx;
  margin: 0 !important;
  padding: 0;
  border: 0;
  border-radius: 2000rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 32% 28%, rgba(255, 255, 255, 0.92), transparent 34%),
    linear-gradient(180deg, #f0f4f8 0%, #e3e8ee 100%);
  box-sizing: border-box;
}

.audio-card-play-btn {
  background: linear-gradient(180deg, #dde4ec 0%, #cfd8e2 100%);
}

.audio-card-btn::after {
  border: none;
}

.audio-card-btn-icon {
  width: 28rpx;
  height: 28rpx;
}

.audio-card-btn-loading {
  width: 28rpx;
  height: 28rpx;
  border-radius: 1998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.audio-card-btn-loading-image {
  width: 100%;
  height: 100%;
  display: block;
  filter: brightness(0) invert(1);
  animation: audioLoadingRotate 0.9s linear infinite;
}

@keyframes audioLoadingRotate {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.audio-card-play-btn-icon {
  filter: brightness(0) saturate(100%);
}

.audio-card-share-btn {
  background: linear-gradient(180deg, rgba(228, 238, 248, 0.98), rgba(211, 226, 242, 0.98));
}

.audio-card-send-btn {
  background: #111111;
}

.audio-card-send-icon {
  filter: brightness(0) invert(1);
}

.audio-share-shell {
  max-width: 664rpx;
}

.audio-page {
  background: #000000;
  color: #ffffff;
}

.audio-page-intro-title,
.audio-card-title {
  color: #ffffff;
}

.audio-page-intro,
.audio-grid-card {
  border-radius: 0;
  background: #111111;
  box-shadow: none;
}

.audio-page-intro-text,
.audio-card-text {
  color: rgba(255, 255, 255, 0.62);
}

.audio-page-intro-tag {
  color: rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.1);
}

.audio-page-intro-tag-primary,
.audio-card-share-btn {
  color: #d3f3ea;
  background: rgba(114, 176, 160, 0.18);
  border-color: rgba(114, 176, 160, 0.28);
  box-shadow: none;
}

.audio-loading-text {
  color: rgba(255, 255, 255, 0.48);
}

.audio-card-avatar {
  border-radius: 16rpx;
  background: #1a1a1a;
  box-shadow: none;
}

.audio-card-btn {
  background: rgba(255, 255, 255, 0.08);
}

.audio-card-play-btn {
  background: rgba(255, 255, 255, 0.12);
}

.audio-card-btn-icon {
  filter: brightness(0) invert(1);
}
