.grid-cut-page {
  min-height: 100vh;
  width: 100%;
  background: #000000;
}

.grid-cut-page-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0;
  width: 100%;
  box-sizing: border-box;
}

.grid-cut-page-intro {
  padding: 20rpx;
  border-radius: 0;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.92), transparent 36%),
    linear-gradient(180deg, #f8f9fb 0%, #f1f4f7 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
}

.grid-cut-page-intro-title {
  display: block;
  color: #111111;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.grid-cut-page-intro-text {
  display: block;
  margin-top: 16rpx;
  color: rgba(17, 17, 17, 0.62);
  font-size: 26rpx;
  line-height: 1.7;
}

.grid-cut-page-intro-tags-scroll {
  width: 100%;
  margin-top: 20rpx;
}

.grid-cut-page-intro-tags {
  display: inline-flex;
  flex-wrap: nowrap;
  gap: 20rpx;
  white-space: nowrap;
}

.grid-cut-page-intro-tag {
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  border-radius: 1998rpx;
  color: rgba(17, 17, 17, 0.72);
  font-size: 22rpx;
  line-height: 1;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid rgba(17, 17, 17, 0.05);
  box-sizing: border-box;
}

.grid-cut-page-intro-tag-primary {
  color: #2f4f76;
  font-weight: 700;
  letter-spacing: 2rpx;
  background: linear-gradient(180deg, rgba(228, 238, 248, 0.98), rgba(211, 226, 242, 0.98));
  border-color: rgba(74, 112, 158, 0.28);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
}

.grid-cut-empty,
.grid-cut-editor-card,
.grid-cut-result-card {
  padding: 20rpx;
  border-radius: 0;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.92), transparent 36%),
    linear-gradient(180deg, #f8f9fb 0%, #f1f4f7 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
}

.grid-cut-empty-title,
.grid-cut-section-title {
  display: block;
  color: #111111;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.3;
}

.grid-cut-empty-text {
  display: block;
  margin-top: 16rpx;
  color: rgba(17, 17, 17, 0.58);
  font-size: 20rpx;
  line-height: 1.6;
}

.grid-cut-editor-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.grid-cut-editor-tip {
  flex-shrink: 0;
  color: rgba(47, 79, 118, 0.88);
  font-size: 22rpx;
  line-height: 1;
  padding: 8rpx 16rpx;
  border-radius: 1998rpx;
  background: rgba(228, 238, 248, 0.9);
  border: 2rpx solid rgba(74, 112, 158, 0.16);
  white-space: nowrap;
}

.grid-cut-editor-frame {
  position: relative;
  overflow: hidden;
  margin: 20rpx auto 0;
  max-width: 100%;
  border-radius: 16rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.24), rgba(255, 255, 255, 0)),
    #eef1f5;
  box-shadow:
  inset 0 0 0 2rpx rgba(17, 17, 17, 0.05),
    0 20rpx 48rpx rgba(17, 17, 17, 0.06);
}

.grid-cut-editor-image {
  position: absolute;
  display: block;
}

.grid-cut-editor-grid {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.grid-cut-editor-grid::before,
.grid-cut-editor-grid::after {
  content: "";
  position: absolute;
  inset: 0;
}

.grid-cut-editor-grid::before {
  background:
    linear-gradient(
      to right,
      transparent 33.2%,
      rgba(255, 255, 255, 0.92) 33.2%,
      rgba(255, 255, 255, 0.92) 33.6%,
      transparent 33.6%,
      transparent 66.5%,
      rgba(255, 255, 255, 0.92) 66.5%,
      rgba(255, 255, 255, 0.92) 66.9%,
      transparent 66.9%
    );
}

.grid-cut-editor-grid::after {
  background:
    linear-gradient(
      to bottom,
      transparent 33.2%,
      rgba(255, 255, 255, 0.92) 33.2%,
      rgba(255, 255, 255, 0.92) 33.6%,
      transparent 33.6%,
      transparent 66.5%,
      rgba(255, 255, 255, 0.92) 66.5%,
      rgba(255, 255, 255, 0.92) 66.9%,
      transparent 66.9%
    );
}

.grid-cut-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 28rpx;
}

.grid-cut-primary-btn,
.grid-cut-secondary-btn {
  width: 100% !important;
  min-width: 0;
  height: 88rpx;
  margin: 0 !important;
  padding: 0 28rpx;
  border: 0;
  border-radius: 1998rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 28rpx;
  font-weight: 700;
}

.grid-cut-primary-btn::after,
.grid-cut-secondary-btn::after {
  border: none;
}

.grid-cut-primary-btn {
  background: #111111;
  color: #ffffff;
}

.grid-cut-empty .grid-cut-primary-btn,
.grid-cut-result-card .grid-cut-primary-btn {
  margin-top: 28rpx !important;
}

.grid-cut-save-hint {
  display: block;
  margin-top: 20rpx;
  color: rgba(17, 17, 17, 0.56);
  font-size: 20rpx;
  line-height: 1.4;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.grid-cut-secondary-btn {
  background: #eceff3;
  color: rgba(17, 17, 17, 0.78);
}

.grid-cut-result-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 20rpx;
}

.grid-cut-result-image {
  position: absolute;
  display: block;
}

.grid-cut-result-image {
  inset: 0;
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.grid-cut-result-item {
  position: relative;
  width: 100%;
  padding-top: 100%;
}

.grid-cut-hidden-canvas {
  position: fixed;
  left: -19998rpx;
  top: -19998rpx;
  width: 1200rpx;
  height: 1200rpx;
  opacity: 0;
  pointer-events: none;
}

.grid-cut-page {
  background: #000000;
  color: #ffffff;
}

.grid-cut-page-intro-title,
.grid-cut-empty-title,
.grid-cut-section-title {
  color: #ffffff;
}

.grid-cut-page-intro,
.grid-cut-empty,
.grid-cut-editor-card,
.grid-cut-result-card {
  border-radius: 0;
  background: #111111;
  box-shadow: none;
}

.grid-cut-page-intro-text,
.grid-cut-empty-text,
.grid-cut-save-hint {
  color: rgba(255, 255, 255, 0.62);
}

.grid-cut-page-intro-tag,
.grid-cut-editor-tip {
  color: rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.1);
}

.grid-cut-page-intro-tag-primary {
  color: #d3f3ea;
  background: rgba(114, 176, 160, 0.18);
  border-color: rgba(114, 176, 160, 0.28);
  box-shadow: none;
}

.grid-cut-editor-frame {
  border-radius: 16rpx;
  background: #1a1a1a;
  box-shadow: none;
}

.grid-cut-primary-btn,
.grid-cut-secondary-btn {
  border-radius: 1998rpx;
}

.grid-cut-result-image {
  border-radius: 16rpx;
}

.grid-cut-primary-btn {
  background: #ffffff;
  color: #111111;
}

.grid-cut-secondary-btn {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.82);
}
