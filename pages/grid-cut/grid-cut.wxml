<view class="grid-cut-page">
  <view class="grid-cut-page-body">
    <view class="grid-cut-page-intro">
      <text class="grid-cut-page-intro-title">朋友圈九宫格切图</text>
      <text class="grid-cut-page-intro-text"
        >选择一张图片，拖动位置后生成九宫格，再一键保存到相册。</text
      >
      <scroll-view
        class="grid-cut-page-intro-tags-scroll"
        scroll-x="{{ true }}"
        enable-flex="{{ true }}"
        show-scrollbar="{{ false }}"
      >
        <view class="grid-cut-page-intro-tags">
          <block
            wx:for="{{ pageIntroTags }}"
            wx:key="*this"
            wx:for-index="index"
          >
            <text
              class="grid-cut-page-intro-tag {{
                index === 0 ? 'grid-cut-page-intro-tag-primary' : ''
              }}"
              >{{ item }}</text
            >
          </block>
        </view>
      </scroll-view>
    </view>

    <ad-custom unit-id="{{ nativeTemplateAdUnitId }}"></ad-custom>

    <view
      wx:if="{{ !sourceImagePath }}"
      class="grid-cut-empty"
    >
      <text class="grid-cut-empty-title">先选择一张图片</text>
      <text class="grid-cut-empty-text">默认按朋友圈九宫格裁成正方形，你可以手动拖动位置。</text>
      <button
        class="grid-cut-primary-btn"
        bindtap="chooseSourceImage"
      >
        选择图片
      </button>
    </view>

    <block wx:else>
      <view class="grid-cut-editor-card">
        <view class="grid-cut-editor-head">
          <text class="grid-cut-section-title">裁切区域</text>
          <text class="grid-cut-editor-tip">拖动或双指缩放</text>
        </view>
        <view
          id="gridCutEditorFrame"
          class="grid-cut-editor-frame"
          style="width: {{ cropBoxSizeRpx }}rpx; height: {{ cropBoxSizeRpx }}rpx;"
          catchtouchstart="handleCropTouchStart"
          catchtouchmove="handleCropTouchMove"
          catchtouchend="handleCropTouchEnd"
          catchtouchcancel="handleCropTouchEnd"
        >
          <image
            class="grid-cut-editor-image"
            src="{{ sourceImagePath }}"
            mode="scaleToFill"
            style="{{ editorImageStyle }}"
          ></image>
          <view class="grid-cut-editor-grid"></view>
        </view>

        <view class="grid-cut-actions">
          <button
            class="grid-cut-secondary-btn"
            bindtap="chooseSourceImage"
          >
            重选图片
          </button>
          <button
            class="grid-cut-primary-btn"
            loading="{{ isGenerating }}"
            bindtap="generateGridImages"
          >
            {{ isGenerating ? "生成中" : "生成九宫格" }}
          </button>
        </view>
      </view>

      <view
        wx:if="{{ generatedImages.length }}"
        class="grid-cut-result-card"
      >
        <text class="grid-cut-section-title">生成结果</text>
        <view class="grid-cut-result-grid">
          <block
            wx:for="{{ generatedImages }}"
            wx:key="key"
          >
            <view class="grid-cut-result-item">
              <image
                class="grid-cut-result-image"
                src="{{ item.path }}"
                mode="aspectFill"
              ></image>
            </view>
          </block>
        </view>
        <button
          class="grid-cut-primary-btn"
          loading="{{ isSaving }}"
          bindtap="handleSaveActionTap"
        >
          {{ isSaving ? "保存中" : saveActionButtonText }}
        </button>
        <text class="grid-cut-save-hint">{{ saveActionHintText }}</text>
      </view>
    </block>
  </view>

  <view class="safe-area-spacer"></view>

  <canvas
    class="grid-cut-hidden-canvas"
    canvas-id="gridCutCanvas"
  ></canvas>
</view>

