.notice-page {
  min-height: 100vh;
  width: 100%;
  display: flex;
  flex-direction: column;
  background: #000000;
  box-sizing: border-box;
}

.notice-page-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0;
  box-sizing: border-box;
}

.notice-panel {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 28rpx 24rpx;
  background: rgba(255, 255, 255, 0.06);
  box-sizing: border-box;
}

.notice-loading {
  min-height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.notice-loading-image-wrap {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.notice-loading-image {
  width: 100%;
  height: 100%;
  display: block;
  filter: brightness(0) invert(1);
  animation: noticeLoadingRotate 0.9s linear infinite;
}

.notice-loading-text,
.notice-empty {
  color: rgba(255, 255, 255, 0.58);
  font-size: 26rpx;
  line-height: 1.5;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.notice-item {
  padding: 24rpx 0;
  border-top: 2rpx solid rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.76);
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-all;
}

.notice-item-first {
  border-top: 0;
}

@keyframes noticeLoadingRotate {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
